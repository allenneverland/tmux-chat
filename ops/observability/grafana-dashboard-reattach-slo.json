{
  "id": null,
  "uid": "reattach-slo",
  "title": "Reattach SLO",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["reattach", "slo", "push-server"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Bell / Agent Event Rate (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(events_bell_total[5m]))",
          "legendFormat": "bell",
          "refId": "A"
        },
        {
          "expr": "sum(rate(events_agent_total[5m]))",
          "legendFormat": "agent",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "APNs Sent / Failed (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(apns_sent_total[5m]))",
          "legendFormat": "sent",
          "refId": "A"
        },
        {
          "expr": "sum(rate(apns_failed_total[5m]))",
          "legendFormat": "failed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Event to APNs Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(event_to_apns_latency_ms_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(event_to_apns_latency_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Notification Route Success Ratio (15m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(route_success_total[15m]) / clamp_min(increase(notification_tap_total[15m]), 1)",
          "legendFormat": "success_ratio",
          "refId": "A"
        },
        {
          "expr": "increase(route_fallback_total[15m]) / clamp_min(increase(notification_tap_total[15m]), 1)",
          "legendFormat": "fallback_ratio",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Invalid Token Cleanup Ratio (24h)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(invalid_token_removed_total[24h]) / clamp_min(increase(invalid_token_detected_total[24h]), 1)",
          "legendFormat": "cleanup_ratio",
          "refId": "A"
        },
        {
          "expr": "increase(invalid_token_detected_total[24h])",
          "legendFormat": "detected_24h",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cleanup_ratio" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          }
        ]
      }
    }
  ]
}
